# lzt-core environment. Copy to .env and fill in. NEVER commit a real .env.
#   cp .env.example .env
# All engine vars are read by EngineConfig with the LZT_ prefix (src/event_engine/config.py).

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — credentials
# ─────────────────────────────────────────────────────────────────────────────

# lzt.market API token(s). Get one at https://lzt.market/account/api
# JSON array (pydantic-settings parses list fields as JSON). Add more, comma-separated:
#   LZT_TOKENS=["token-a","token-b"]
LZT_TOKENS=["paste-your-token-here"]

# Management-API admin key (wave-04 subscriptions endpoints). Generate a strong one:
#   openssl rand -hex 32
LZT_ADMIN_API_KEY=replace-with-openssl-rand-hex-32

# ─────────────────────────────────────────────────────────────────────────────
# Stores (self-hosted Postgres 16 + Redis 7). In compose these are overridden to
# the service hostnames; for a bare-metal/systemd run set the real URLs here.
# ─────────────────────────────────────────────────────────────────────────────
LZT_DATABASE_URL=postgresql://lzt:lzt@localhost:5432/lzt_core
LZT_REDIS_URL=redis://localhost:6379/0

# Postgres container credentials (deploy/docker-compose.yml). Keep in sync with
# the user:password:db in LZT_DATABASE_URL.
POSTGRES_USER=lzt
POSTGRES_PASSWORD=lzt
POSTGRES_DB=lzt_core

# Host ports the compose stack publishes postgres/redis on (loopback-only;
# optional, for host-side psql/redis-cli access). Deliberately NOT 5432/6379 —
# specific non-standard numbers so they don't collide with another project's
# own Postgres/Redis on a shared box.
LZT_POSTGRES_PORT=27542
LZT_REDIS_PORT=27541

# ─────────────────────────────────────────────────────────────────────────────
# Polling / cadence (safe defaults; tune per token budget)
# ─────────────────────────────────────────────────────────────────────────────
# JSON array of Category enum values to poll, e.g. ["steam","fortnite"].
LZT_CATEGORIES=["steam"]
LZT_MIN_CADENCE=6.0
LZT_MAX_CADENCE=120.0
LZT_DEFAULT_CADENCE=30.0
LZT_PER_PAGE=50

# Disappearance confirmation (a lot must be missing this many polls before "sold").
LZT_DISAPPEAR_POLLS=3
LZT_CONFIRM_BUDGET_FRACTION=0.25
LZT_CONFIRM_BATCH_SIZE=50

# ─────────────────────────────────────────────────────────────────────────────
# Ingest / batching
# ─────────────────────────────────────────────────────────────────────────────
LZT_SEEN_TTL_SECONDS=86400
LZT_BATCH_SIZE=50
LZT_BATCH_LINGER=0.05

# ─────────────────────────────────────────────────────────────────────────────
# Delivery / retention / limits
# ─────────────────────────────────────────────────────────────────────────────
LZT_MAX_HANDLE_ATTEMPTS=5
LZT_RETENTION_MONTHS=3
LZT_MAX_SINK_LAG=100000

# Analytics thresholds.
LZT_WARN_WINDOW_HOURS=24.0
# price < ai_price * threshold => DealDetected
LZT_DEAL_THRESHOLD=0.85

# ─────────────────────────────────────────────────────────────────────────────
# Domain + automatic TLS (optional — scripts/setup_tls.sh: host nginx + certbot).
# Leave both unset to run without a public domain (loopback-only, no TLS).
# ─────────────────────────────────────────────────────────────────────────────
# Public domain pointing at this host (A/AAAA record). scripts/setup_tls.sh
# (host nginx + certbot) issues and auto-renews a Let's Encrypt certificate for
# it once ports 80/443 are reachable.
LZT_DOMAIN=
# Email Let's Encrypt uses for expiry/revocation notices (required by ACME ToS
# once LZT_DOMAIN is set).
LZT_ACME_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────
# Daemon HTTP server (/healthz, /readyz, /metrics)
# ─────────────────────────────────────────────────────────────────────────────
LZT_HEALTH_HOST=0.0.0.0
LZT_HEALTH_PORT=27543

# Postgres advisory-lock key (single-writer election) + run identity.
LZT_ADVISORY_LOCK_KEY=1819571811
LZT_RUN_ID=engine
